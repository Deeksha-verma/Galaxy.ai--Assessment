# ==========================================
# Backend Environment Variables
# Copy to backend/.env.local and fill in values
# ==========================================

# ── Server Config ──
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database (Postgres) ──
# Required by Prisma (e.g., Supabase or Neon DB connection string)
DATABASE_URL=postgresql://user:password@host:port/dbname?schema=public

# ── Authentication (Clerk) ──
# Get this from your Clerk Dashboard -> API Keys
CLERK_SECRET_KEY=sk_test_...

# ── Task Queue (Trigger.dev) ──
# Get this from Trigger.dev project settings -> API Keys
TRIGGER_SECRET_KEY=tr_test_...

# ── AI Model (Google Gemini) ──
# Get this from Google AI Studio
GEMINI_API_KEY=AIzaSy...

# ── Video Processing (Transloadit) ──
# Get these from Transloadit Dashboard -> Credentials
TRANSLOADIT_AUTH_KEY=...
TRANSLOADIT_AUTH_SECRET=...
